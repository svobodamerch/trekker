# Production environment configuration for Beta Deployment
# Copy this file to .env and fill in real values

# Application Environment
APP_ENV=production

# Database - PostgreSQL for production
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://username:password@localhost:5432/trekker_beta

# Security
JWT_SECRET=generate-strong-random-secret-at-least-32-chars

# Telegram Bot
BOT_TOKEN=your_bot_token_from_botfather
MINI_APP_URL=https://your-frontend-url.vercel.app
BACKEND_URL=https://your-backend-url.railway.app

# Auth - disable mock mode in production
TELEGRAM_AUTH_MOCK=false

# AI - optional for beta (placeholder mode works without key)
AI_API_KEY=your_openai_or_anthropic_key_optional
AI_MODEL=gpt-4

# CORS - allow production frontend
CORS_ORIGINS=https://your-frontend-url.vercel.app,https://your-custom-domain.com
